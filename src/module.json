  "capabilities": {
    "audio_out": true,
    "audio_in": false,
    "midi_in": true,
    "midi_out": false,
    "aftertouch": false,
    "chainable": true,
    "component_type": "sound_generator",
    "ui_hierarchy": {
      "levels": {
        "root": {
          "name": "MrDrums",
          "params": [
            { "label": "Global", "level": "global" },
            { "label": "Pad Settings", "level": "pad_settings" }
          ],
          "knobs": ["ui_auto_select_pad", "pad_vol", "pad_pan", "pad_tune", "pad_start", "pad_attack_ms", "pad_decay_ms", "pad_choke_group", "pad_mode"]
        },
        "global": {
          "name": "Global",
          "params": ["g_master_vol", "g_polyphony", "g_vel_curve", "g_humanize_ms", "g_rand_seed", "g_rand_loop_steps"],
          "knobs": ["g_master_vol", "g_polyphony", "g_vel_curve", "g_humanize_ms", "g_rand_seed", "g_rand_loop_steps"]
        },
        "pad_settings": {
          "name": "Pad Settings",
          "params": [
            "ui_auto_select_pad",
            "ui_current_pad",
            "ui_pad_page",
            { "key": "pad_sample_path", "visible_if": { "param": "ui_pad_page", "equals": "main" } },
            { "key": "pad_vol", "visible_if": { "param": "ui_pad_page", "equals": "main" } },
            { "key": "pad_pan", "visible_if": { "param": "ui_pad_page", "equals": "main" } },
            { "key": "pad_tune", "visible_if": { "param": "ui_pad_page", "equals": "main" } },
            {
              "key": "pad_start",
              "type": "wav_position",
              "min": 0,
              "max": 100,
              "step": 1,
              "options": {
                "display_unit": "percent",
                "mode": "trim_front",
                "filepath_param": "pad_sample_path",
                "shift_increment_multiplier": 0.25
              },
              "visible_if": { "param": "ui_pad_page", "equals": "main" }
            },
            { "key": "pad_attack_ms", "visible_if": { "param": "ui_pad_page", "equals": "main" } },
            { "key": "pad_decay_ms", "visible_if": { "param": "ui_pad_page", "equals": "main" } },
            { "key": "pad_choke_group", "visible_if": { "param": "ui_pad_page", "equals": "main" } },
            { "key": "pad_mode", "visible_if": { "param": "ui_pad_page", "equals": "main" } },
            { "key": "pad_rand_pan_amt", "visible_if": { "param": "ui_pad_page", "equals": "random" } },
            { "key": "pad_rand_vol_amt", "visible_if": { "param": "ui_pad_page", "equals": "random" } },
            { "key": "pad_rand_decay_amt", "visible_if": { "param": "ui_pad_page", "equals": "random" } },
            { "key": "pad_chance_pct", "visible_if": { "param": "ui_pad_page", "equals": "random" } }
          ],
          "knobs": ["ui_auto_select_pad", "ui_current_pad", "ui_pad_page", "pad_vol", "pad_pan", "pad_tune", "pad_start", "pad_attack_ms", "pad_decay_ms", "pad_choke_group", "pad_mode", "pad_rand_pan_amt", "pad_rand_vol_amt", "pad_rand_decay_amt", "pad_chance_pct"]
        }
      }
    }
